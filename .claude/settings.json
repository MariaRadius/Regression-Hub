{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "cp CLAUDE.md AGENTS.md && git add AGENTS.md 2>/dev/null || true",
            "shell": "bash",
            "statusMessage": "Syncing AGENTS.md from CLAUDE.md..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint:fix > /dev/null 2>&1 || true",
            "shell": "bash",
            "timeout": 120,
            "statusMessage": "Running lint:fix..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
