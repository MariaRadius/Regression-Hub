# @visx/* (axis, group, grid, scale, shape, etc.) cap their React peer at 18.
# They are runtime-compatible with React 19 — the build compiles and the test
# suite passes — but plain `npm i` / `npm ci` hard-ERESOLVE on the declared cap.
# Remove this once @visx ships a stable v4 with a React 19 peer range.
legacy-peer-deps=true
